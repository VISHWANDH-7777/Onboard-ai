# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: The connection string for MongoDB.
# Example: mongodb://localhost:27017/my-database
MONGODB_URI=

# MONGODB_DB: Optional MongoDB database name.
MONGODB_DB=nebula_ai

# API_PORT: Optional backend server port.
API_PORT=3001

# JWT_SECRET: Required for signing auth tokens in production.
JWT_SECRET=

# JWT_EXPIRES_IN: Token expiration window.
JWT_EXPIRES_IN=7d

# GOOGLE_CLIENT_ID: Google OAuth client ID used by backend token verification.
GOOGLE_CLIENT_ID=

# VITE_GOOGLE_CLIENT_ID: Frontend Google Identity Services client ID.
# Keep this in your frontend env file (for example .env.local).
VITE_GOOGLE_CLIENT_ID=
